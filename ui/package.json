{
  "name": "yz-pixel-ring-ui",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Control UI for the ReSpeaker pixel-ring daemon — builds a standalone SPA and a JarvYZ-embeddable IIFE.",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build:pages": "tsc --noEmit && vite build",
    "build:lib": "tsc --noEmit && vite build --mode lib",
    "build": "tsc --noEmit && vite build && vite build --mode lib",
    "preview": "vite preview --port 9701"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.1.0",
    "@mui/material": "^6.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
